generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  name              String    @db.VarChar(100)
  organization      String?   @db.VarChar(200)
  position          String?   @db.VarChar(100)
  email             String?   @db.VarChar(200)
  phone             String?   @db.VarChar(50)
  businessCardUrl   String?   @map("business_card_url")
  businessCardOcr   Json?     @map("business_card_ocr")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  meetings        Meeting[]
  meetingContacts MeetingContact[]

  @@map("contacts")
}

model Meeting {
  id                  String        @id @default(uuid())
  userId              String        @map("user_id")
  contactId           String?       @map("contact_id")
  title               String?       @db.VarChar(200)
  mode                MeetingMode
  audioUrl            String?       @map("audio_url")
  durationSeconds     Int?          @map("duration_seconds")
  transcript          String?
  agenda              String?
  transcriptSegments  Json?         @map("transcript_segments")
  aiAnalysis          Json?         @map("ai_analysis")
  status              MeetingStatus @default(recording)
  date                DateTime      @default(now()) @db.Date
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  contact             Contact?         @relation(fields: [contactId], references: [id])
  meetingContacts     MeetingContact[]
  mindmapNodes        MindmapNode[]
  topicItemMeetings   TopicItemMeeting[]
  meetingTopics       MeetingTopic[]
  captures            Capture[]

  @@map("meetings")
}

model MeetingContact {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  contactId String   @map("contact_id")
  createdAt DateTime @default(now()) @map("created_at")

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([meetingId, contactId])
  @@map("meeting_contacts")
}

enum MeetingMode {
  live
  import
  recall
}

enum MeetingStatus {
  recording
  processing
  completed
}

model MindmapNode {
  id          String    @id @default(uuid())
  meetingId   String    @map("meeting_id")
  parentId    String?   @map("parent_id")
  label       String    @db.VarChar(200)
  nodeType    NodeType  @map("node_type")
  status      String?   @db.VarChar(50)
  isVisible   Boolean   @default(true) @map("is_visible")
  isSecret    Boolean   @default(false) @map("is_secret")
  isStarred   Boolean   @default(false) @map("is_starred")
  color       String?   @db.VarChar(20)
  positionX   Float?    @map("position_x")
  positionY   Float?    @map("position_y")
  metadata    Json?
  sortOrder   Int?      @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  meeting        Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  parent         MindmapNode?  @relation("NodeChildren", fields: [parentId], references: [id])
  children       MindmapNode[] @relation("NodeChildren")
  crossLinksFrom CrossLink[]   @relation("CrossLinkFrom")
  crossLinksTo   CrossLink[]   @relation("CrossLinkTo")

  @@map("mindmap_nodes")
}

model CrossLink {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  fromNodeId         String            @map("from_node_id")
  toNodeId           String            @map("to_node_id")
  strength           CrossLinkStrength @default(medium)
  category           String?           @db.VarChar(100)
  categoryColor      String?           @map("category_color") @db.VarChar(20)
  reason             String?
  newValueSuggestion String?           @map("new_value_suggestion")
  isAiGenerated      Boolean           @default(true) @map("is_ai_generated")
  isAccepted         Boolean?          @map("is_accepted")
  isVisible          Boolean           @default(true) @map("is_visible")
  sharedTags         String[]          @default([]) @map("shared_tags")
  createdAt          DateTime          @default(now()) @map("created_at")

  fromNode           MindmapNode       @relation("CrossLinkFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode             MindmapNode       @relation("CrossLinkTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@map("cross_links")
}

enum CrossLinkStrength {
  strong
  medium
  weak
}

enum NodeType {
  root
  topic
  item
  action
}

model Topic {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  name      String    @db.VarChar(100)
  status    String    @default("active") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  items         TopicItem[]
  meetingTopics MeetingTopic[]

  @@unique([userId, name])
  @@map("topics")
}

model MeetingTopic {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  topicId   String   @map("topic_id")
  createdAt DateTime @default(now()) @map("created_at")

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([meetingId, topicId])
  @@map("meeting_topics")
}

model TopicItem {
  id          String    @id @default(uuid())
  topicId     String    @map("topic_id")
  name        String    @db.VarChar(200)
  description String?
  status      String?   @db.VarChar(50)
  isVisible   Boolean   @default(true) @map("is_visible")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  meetings    TopicItemMeeting[]

  @@map("topic_items")
}

model TopicItemMeeting {
  id          String    @id @default(uuid())
  topicItemId String    @map("topic_item_id")
  meetingId   String    @map("meeting_id")
  excerpt     String?
  createdAt   DateTime  @default(now()) @map("created_at")

  topicItem   TopicItem @relation(fields: [topicItemId], references: [id], onDelete: Cascade)
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("topic_item_meetings")
}

model QuickMemo {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  content   String
  tags      String[] @default([])
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("quick_memos")
}

model ShareLink {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  token        String    @unique @db.VarChar(64)
  viewType     ViewType  @map("view_type")
  filterConfig Json?     @map("filter_config")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("share_links")
}

enum ViewType {
  full_map
  topic
  meeting
}

enum CaptureSource {
  shortcut
  voice
  line
  obsidian
  meetingmap
  clip
  consult
}

model Capture {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  source           CaptureSource
  content          String
  tags             String[]      @default([])
  meetingId        String?       @map("meeting_id")
  lineMessageId    String?       @unique @map("line_message_id")
  syncedToObsidian Boolean       @default(false) @map("synced_to_obsidian")
  url              String?       @map("url")
  why              String?       @map("why")
  summary          String?       @map("summary")
  useFor           String[]      @default([]) @map("use_for")
  keywords         String[]      @default([]) @map("keywords")
  createdAt        DateTime      @default(now()) @map("created_at")

  meeting Meeting? @relation(fields: [meetingId], references: [id])

  @@index([userId, tags])
  @@index([userId, syncedToObsidian])
  @@map("captures")
}

model CaptureTagDef {
  slug        String   @id
  label       String
  description String?
  active      Boolean  @default(true)
  isProject   Boolean  @default(false) @map("is_project")
  sortOrder   Int      @default(100) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("capture_tag_defs")
}

model DeviceToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceName String?   @map("device_name")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("device_tokens")
}
